# -----------------------------------------------------------------------------
# Gateway process settings only — NOT credentials inventory.
# Official Grok accounts are added at http://127.0.0.1:8787/admin
#   · Device Code / import xai-*.json → ~/.grok2api/auths
# -----------------------------------------------------------------------------

HOST=127.0.0.1
PORT=8787

# Client + admin door key (Bearer / x-api-key / x-admin-key). Generate your own.
GROK2API_API_KEY=sk-change-me

# auto | oauth | credential  (official Grok only; legacy "compat" maps to auto)
# auto = prefer official credential when present
UPSTREAM_MODE=auto

# Optional overrides (defaults under ~/.grok2api)
# GROK2API_DATA_DIR=
# OAUTH_AUTHS_DIR=
# OAUTH_TOKEN_FILE=

MODEL_ALIASES=
DEFAULT_MODELS=grok-3,grok-3-mini
UPSTREAM_TIMEOUT=600
LOG_LEVEL=info

# Request metadata logs for /admin (JSONL under ~/.grok2api/logs)
REQUEST_LOG_ENABLED=true
REQUEST_LOG_KEEP_DAYS=7
REQUEST_LOG_MAX_MB=50
# 0 = do not store request bodies
REQUEST_LOG_BODY_MAX=0
