# -----------------------------------------------------------------------------
# Gateway process settings only — NOT upstream inventory.
# Channels / Grok accounts are added at http://127.0.0.1:8787/admin
#   · Mid-station → ~/.grok2api/providers.json
#   · Official Grok → ~/.grok2api/auths/xai-*.json
# -----------------------------------------------------------------------------

HOST=127.0.0.1
PORT=8787

# Client + admin door key (Bearer / x-api-key / x-admin-key). Generate your own.
GROK2API_API_KEY=sk-change-me

# auto | compat | oauth | credential
# auto = use official Grok if credential present, else managed mid-station channels
UPSTREAM_MODE=auto

# Optional overrides (defaults under ~/.grok2api)
# GROK2API_DATA_DIR=
# OAUTH_AUTHS_DIR=
# OAUTH_TOKEN_FILE=

MODEL_ALIASES=
DEFAULT_MODELS=grok-3,grok-3-mini
UPSTREAM_TIMEOUT=600
LOG_LEVEL=info
