# -----------------------------------------------------------------------------
# compat = OpenAI-compatible mid-station / custom API (DEFAULT)
# Example: iamhc, NewAPI, OpenRouter — independent of official Grok
# -----------------------------------------------------------------------------
XAI_API_KEY=
XAI_BASE_URL=https://api.iamhc.cn/v1
# If XAI_API_KEY empty, falls back to VOYA_API_KEY / OPENAI_API_KEY from environment

# Multi custom OpenAI-compatible upstreams (optional). Path or inline JSON.
# OPENAI_COMPATIBILITY=examples/openai-compatibility.json

# -----------------------------------------------------------------------------
# Official Grok account tokens (auths dir: ~/.grok2api/auths/xai-*.json)
#   oauth      — Device Code: python -m app.oauth.login
#   credential — import file: python -m app.oauth.login --import path
#               or paste/upload on /admin
# Set UPSTREAM_MODE only when the gateway should use that official account.
# Does NOT change your Grok Build [model.voya] / iamhc custom model.
# -----------------------------------------------------------------------------
# UPSTREAM_MODE: compat | oauth | credential
UPSTREAM_MODE=compat
# OAUTH_AUTHS_DIR=
# OAUTH_TOKEN_FILE=

HOST=127.0.0.1
PORT=8787
# Client key for this gateway (Bearer / x-api-key). Generate your own.
GROK2API_API_KEY=sk-change-me

MODEL_ALIASES=
DEFAULT_MODELS=DeepSeek-V4-Pro,grok-4.5,grok-3
UPSTREAM_TIMEOUT=600
LOG_LEVEL=info
